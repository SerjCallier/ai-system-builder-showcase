# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_brain
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ─── LLM (Anthropic / Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-real-key-here
LLM_FAST_MODEL=claude-sonnet-4-5
LLM_DEEP_MODEL=claude-opus-4-5
LLM_LOCAL_MODEL=ollama/llama3

# ─── Slack Notification Webhooks ──────────────────────────────────────────────
SLACK_WEBHOOK_URGENT=your_slack_webhook_urgent_here
SLACK_WEBHOOK_CONTENT=your_slack_webhook_content_here
SLACK_WEBHOOK_ADS=your_slack_webhook_ads_here

# ─── Facebook Marketing API ───────────────────────────────────────────────────
FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
FB_ACCESS_TOKEN=your_fb_system_user_access_token
FB_AD_ACCOUNT_ID=act_your_ad_account_id

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_wa_access_token
WA_VERIFY_TOKEN=your_custom_verify_token

# ─── SEMrush ──────────────────────────────────────────────────────────────────
SEMRUSH_API_KEY=your_semrush_api_key

# ─── General ──────────────────────────────────────────────────────────────────
# Set to "false" when using real credentials and a real PostgreSQL instance
MOCK_MODE=true
LOG_LEVEL=INFO
